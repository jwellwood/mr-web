#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run ESLint and auto-fix issues
echo "📝 Linting and fixing code..."
npm run lint-fix

# Stage any auto-fixed files
git add -u

# Run i18n parity check
echo "🌐 Checking locale parity..."
npm run i18n:check

# Run tests with coverage
echo "🧪 Running tests with coverage checks..."
npm run test:coverage

# Run codegen
echo "🔧 Running GraphQL codegen..."
npm run codegen

# Stage generated files so the commit includes the latest outputs
git add -A

if [ -n "$(git status --porcelain)" ]; then
  echo "✅ Codegen ran and changes were staged. Commit will include generated files."
fi

echo "✅ Pre-commit checks passed!"
